APP_NAME=HRCloud Biometric Admin API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8090
LOG_LEVEL=INFO
API_PREFIX=/api/v1

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=attendance
SB_TIMEOUT=10

DEFAULT_TIMEZONE=America/Guayaquil
ENABLE_MOCK_PROVIDER=true
