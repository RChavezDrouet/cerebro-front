{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/components/AppShell.tsx",
    "src/components/ProtectedRoute.tsx",
    "src/components/TenantGate.tsx",
    "src/config/**",
    "src/employees/**",
    "src/pages/DashboardPage.tsx",
    "src/pages/ResetPasswordPage.tsx",
    "src/pages/reports/**",
    "src/snippets/**",
    "src/store/**"
  ]
}