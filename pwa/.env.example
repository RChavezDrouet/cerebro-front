# =============================================
# HRCloud PWA — Variables de entorno (Vite)
# Copia este archivo como .env.local y completa los valores.
# =============================================

# Supabase
VITE_SUPABASE_URL=https://<TU-PROYECTO>.supabase.co
VITE_SUPABASE_ANON_KEY=<TU_ANON_KEY_SIN_ESPACIOS>

# App (opcional)
VITE_APP_NAME=HRCloud PWA
VITE_APP_VERSION=1.0.0

# Marcación remota (tuning)
# Radio máximo permitido (metros) para geofence (si el empleado tiene geofence configurado)
VITE_GEO_MAX_METERS=400

# Precisión GPS mínima aceptable (metros). Mientras más pequeño, más exigente.
VITE_MIN_GPS_ACCURACY=50

# Umbral para futura comparación facial (placeholder en MVP)
VITE_FACE_THRESHOLD=0.6

# Verificación facial (BACKEND)
# strict  -> exige respuesta OK del backend (recomendado)
# mvp     -> si falla el backend, permite marcar (solo para DEV)
VITE_FACE_VERIFY_MODE=strict

# Nombre de la Edge Function en Supabase (Functions)
VITE_FACE_VERIFY_FUNCTION=face-verify

# Bucket para selfies de marcación
VITE_SELFIE_BUCKET=punch-selfies

# Valores por defecto para INSERT en attendance.punches (alineado a Base)
# - status es TEXT en tu BD
# - verification puede ser INT/TEXT según implementación (enviamos número por defecto)
VITE_WEB_PUNCH_STATUS=0
VITE_WEB_PUNCH_VERIFICATION=15

# Mensaje por defecto si el tenant está paused (si no existe paused_message en DB)
VITE_TENANT_PAUSED_MESSAGE=Tu empresa se encuentra temporalmente suspendida. Contacta a RRHH o al administrador.
